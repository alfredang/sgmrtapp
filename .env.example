# Copy to a gitignored `.env` at the repo root and fill in. Load before running scripts:
#   set -a; source .env; set +a
# The `.p8` private key itself is NEVER committed — keep it at ASC_PRIVATE_KEY_PATH.

# --- App Store Connect API credentials (your automation key) ---
ASC_KEY_ID=<ASC_KEY_ID>                  # 10-char Key ID from Users and Access → Integrations
ASC_ISSUER_ID=<ASC_ISSUER_ID>            # xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_<ASC_KEY_ID>.p8

# --- App identity ---
TEAM_ID=<TEAM_ID>
APP_NAME=SGMRT
BUNDLE_ID=com.alfredang.sgmrt
ASC_APP_NAME=SGMRT
ASC_BUNDLE_ID=com.alfredang.sgmrt        # reverse-DNS bundle id
ASC_SKU=SGMRT001
ASC_APP_ID=<APP_ID>                      # numeric ASC App ID

# --- Version metadata --- (quote any value with spaces so `source .env` works)
ASC_COPYRIGHT="2026 Tertiary Infotech Academy Pte. Ltd."
ASC_PRIVACY_POLICY_URL="https://www.tertiarycourses.com.sg/privacy-policy"
ASC_SUPPORT_URL="https://github.com/alfredang/sgmrtapp/issues"
ASC_MARKETING_URL="https://github.com/alfredang/sgmrtapp"

# --- App Review contact ---
ASC_CONTACT_FIRST="<First>"
ASC_CONTACT_LAST="<Last>"
ASC_CONTACT_PHONE="+10000000000"
ASC_CONTACT_EMAIL="<CONTACT_EMAIL>"
# No login required for SGMRT — reviewers can use the app directly.
ASC_REVIEW_NOTES="No account is required. Launch the app, browse the Singapore MRT map, select start and destination stations, and view the shortest route estimate. Live context is loaded from LTA DataMall when available."
